# ระบุชื่อตัวแปรที่ใช้ใน compose.yaml เพื่อให้สอดคล้องกับการใช้งานในไฟล์นั้น
PROJECT_NAME= "Panuwad_project" # ใส่ชื่อโปรเจคของคุณ
MY_USERNAME= "Panuwad"#ใส่ชื่อผู้ใช้ของคุณ
# พอร์ตที่ใช้สำหรับบริการต่าง ๆ

# พอร์ตสำหรับ Web Proxy (Nginx)
HTTP_PORT= "14001"
# พอร์ตสำหรับ phpMyAdmin
PMA_PORT= "14002"
# DB Details
DB_USER= "root"
DB_NAME= "panuwad-db"